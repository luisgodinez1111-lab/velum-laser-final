{
  "name": "velum-laser",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "codegen": "./scripts/generate-api-types.sh",
    "codegen:check": "./scripts/generate-api-types.sh --check",
    "tokens:build": "tsx design/tokens.css.ts > design/tokens.css",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "size-check": "size-limit"
  },
  "dependencies": {
    "@sentry/react": "^10.50.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.12.0"
  },
  "size-limit": [
    {
      "name": "JS inicial (entry chunk)",
      "path": "dist/assets/index-*.js",
      "limit": "70 KB",
      "gzip": true
    },
    {
      "name": "Vendor React",
      "path": "dist/assets/vendor-react-*.js",
      "limit": "70 KB",
      "gzip": true
    },
    {
      "name": "CSS total",
      "path": "dist/assets/*.css",
      "limit": "60 KB",
      "gzip": true
    }
  ],
  "devDependencies": {
    "@size-limit/file": "^12.1.0",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.8",
    "size-limit": "^12.1.0",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.0"
  }
}
