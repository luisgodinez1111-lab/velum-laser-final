# ── Velum Laser — Frontend — Variables de Entorno ────────────────────────────
# Copia este archivo como .env y ajusta los valores para tu entorno local.
# Para producción configura estas variables en tu plataforma de deploy (Vercel, Netlify, etc.)

# URL base de la API backend.
#   Desarrollo local con proxy Vite (recomendado): VITE_API_URL=/api
#   Producción apuntando directo al backend:       VITE_API_URL=https://api.tudominio.com/api
VITE_API_URL=/api

# ── Observabilidad (Sentry) ─────────────────────────────────────────────
# Si VITE_SENTRY_DSN está vacío, Sentry NO se inicializa (cero overhead).
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
# Sample rate de tracing (0.0 a 1.0). Defecto 0.1 = 10% de transacciones.
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# Replay rate (0 = desactivado, costoso). Errores SIEMPRE reproducen al 100%.
VITE_SENTRY_REPLAY_SAMPLE_RATE=0
