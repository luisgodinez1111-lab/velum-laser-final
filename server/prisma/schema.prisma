generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  member
  staff
  admin
  system
}

enum MembershipStatus {
  inactive
  active
  past_due
  canceled
  paused
}

enum DocumentStatus {
  pending
  signed
  rejected
}

enum IntakeStatus {
  draft
  submitted
  approved
  rejected
}

enum AppointmentStatus {
  scheduled
  confirmed
  completed
  canceled
  no_show
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum CustomChargeType {
  ONE_TIME
  RECURRING
}

enum CustomChargeStatus {
  PENDING_ACCEPTANCE
  ACCEPTED
  PAID
  EXPIRED
  CANCELLED
}

enum CustomChargeInterval {
  day
  week
  month
  year
  once
}

enum IntegrationJobStatus {
  pending
  processing
  done
  failed
}

enum TenantStatus {
  trial
  active
  suspended
  churned
}

enum OutboxStatus {
  pending
  processing
  done
  failed
  dead
}

enum TenantPlanTier {
  starter
  professional
  enterprise
  internal
}

enum TenantRegion {
  mx
  us
  eu
}

/// Raíz del modelo multi-tenant. Cada fila operacional pertenece a un Tenant
/// vía `clinicId` (renombrado a `tenantId` en una migración futura).
/// El primer tenant tiene id literal 'default' por compatibilidad con
/// las columnas `clinicId` existentes que tienen DEFAULT 'default'.
model Tenant {
  id              String         @id @default(cuid())
  slug            String         @unique
  legalName       String
  displayName     String
  status          TenantStatus   @default(trial)
  planTier        TenantPlanTier @default(starter)
  region          TenantRegion   @default(mx)
  timezone        String         @default("America/Chihuahua")
  locale          String         @default("es-MX")
  primaryDomain   String?        @unique
  billingEmail    String?
  contactPhone    String?
  taxId           String?
  features        Json           @default("{}")
  limits          Json           @default("{}")
  trialEndsAt     DateTime?      @db.Timestamptz
  suspendedAt     DateTime?      @db.Timestamptz
  suspendedReason String?
  createdAt       DateTime       @default(now()) @db.Timestamptz
  updatedAt       DateTime       @updatedAt @db.Timestamptz
  deletedAt       DateTime?      @db.Timestamptz

  // Relaciones inversas — toda fila tenant-scoped cuelga de aquí.
  // El nombre del scalar sigue siendo `clinicId` por compatibilidad;
  // el rename a `tenantId` viene en una migración posterior.
  users                      User[]
  appointments               Appointment[]
  integrationJobs            IntegrationJob[]
  googleCalendarIntegrations GoogleCalendarIntegration[]
  outboxEvents               OutboxEvent[]
  memberships                Membership[]
  payments                   Payment[]
  documents                  Document[]
  medicalIntakes             MedicalIntake[]
  sessionTreatments          SessionTreatment[]
  customCharges              CustomCharge[]
  notifications              Notification[]
  auditLogs                  AuditLog[]
  profiles                   Profile[]
  refreshTokens              RefreshToken[]
  emailVerificationTokens    EmailVerificationToken[]
  passwordResetTokens        PasswordResetToken[]
  consentOtpTokens           ConsentOtpToken[]
  passwordHistories          PasswordHistory[]
  whatsappOtps               WhatsappOtp[]
  deleteOtps                 DeleteOtp[]
  leads                      Lead[]
  marketingAttributions      MarketingAttribution[]
  agendaPolicies             AgendaPolicy[]
  agendaCabins               AgendaCabin[]
  agendaTreatments           AgendaTreatment[]
  agendaTreatmentCabinRules  AgendaTreatmentCabinRule[]
  agendaWeeklyRules          AgendaWeeklyRule[]
  agendaSpecialDateRules     AgendaSpecialDateRule[]
  agendaBlockedSlots         AgendaBlockedSlot[]

  @@index([region])
}

/// Embeddings vectoriales de MedicalIntake para RAG (Movimiento #8).
/// Tenant-scoped via RLS. El campo `embedding` es vector(1536) — Prisma
/// no lo soporta nativamente, lo manejamos via $queryRaw.
model MedicalIntakeEmbedding {
  id         String   @id @default(cuid())
  tenantId   String
  intakeId   String
  chunkIndex Int
  chunkType  String
  content    String
  model      String
  tokens     Int?
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  intake MedicalIntake @relation(fields: [intakeId], references: [id], onDelete: Cascade)

  @@unique([intakeId, chunkIndex, chunkType])
  @@index([tenantId])
  @@index([intakeId])
}

/// Outbox pattern (Fase 1.2). Eventos de dominio escritos atomicamente con
/// la transaccion que los origina; despachados asincronicamente por el worker.
model OutboxEvent {
  id            String       @id @default(cuid())
  tenantId      String
  eventType     String
  aggregateType String
  aggregateId   String
  payload       Json
  status        OutboxStatus @default(pending)
  attempts      Int          @default(0)
  maxAttempts   Int          @default(8)
  availableAt   DateTime     @default(now()) @db.Timestamptz
  lockedUntil   DateTime?    @db.Timestamptz
  processedAt   DateTime?    @db.Timestamptz
  lastError     String?
  createdAt     DateTime     @default(now()) @db.Timestamptz
  updatedAt     DateTime     @updatedAt @db.Timestamptz
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // La partial index del dispatch path se define en SQL porque Prisma no
  // modela indices parciales.
  @@index([tenantId, status], map: "OutboxEvent_tenantId_status_idx")
  @@index([aggregateType, aggregateId], map: "OutboxEvent_aggregate_idx")
  @@index([eventType, createdAt], map: "OutboxEvent_eventType_createdAt_idx")
}

model User {
  id                          String                   @id @default(cuid())
  email                       String                   @unique
  passwordHash                String
  role                        Role                     @default(member)
  clinicId                    String                   @default("default")
  stripeCustomerId            String?                  @unique
  emailVerifiedAt             DateTime?
  isActive                    Boolean                  @default(true)
  deactivatedAt               DateTime?
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt
  profile                     Profile?
  memberships                 Membership[]
  documents                   Document[]
  medicalIntake               MedicalIntake?
  appointments                Appointment[]            @relation("AppointmentMember")
  createdAppointments         Appointment[]            @relation("AppointmentCreator")
  sessionsAsMember            SessionTreatment[]       @relation("SessionMember")
  sessionsAsStaff             SessionTreatment[]       @relation("SessionStaff")
  payments                    Payment[]
  leadConversions             Lead[]                   @relation("LeadConvertedUser")
  marketingAttributions       MarketingAttribution[]   @relation("MarketingAttributionUser")
  auditLogs                   AuditLog[]               @relation("AuditLogLegacy")
  auditLogsActor              AuditLog[]               @relation("AuditLogActor")
  auditLogsTarget             AuditLog[]               @relation("AuditLogTarget")
  approvedIntakes             MedicalIntake[]          @relation("MedicalIntakeApprover")
  emailVerifications          EmailVerificationToken[]
  passwordResets              PasswordResetToken[]
  consentOtps                 ConsentOtpToken[]
  agendaBlocksCreated         AgendaBlockedSlot[]      @relation("AgendaBlockedSlotCreator")
  appointmentDepositAvailable Boolean                  @default(false)
  interestedPlanCode          String?
  passwordChangedAt           DateTime?
  mustChangePassword          Boolean                  @default(false)
  customCharges               CustomCharge[]
  notifications               Notification[]
  refreshTokens               RefreshToken[]
  passwordHistory             PasswordHistory[]
  deletedAt                   DateTime?
  deletedBy                   String?
  loginFailedCount            Int                      @default(0)
  loginLockedUntil            DateTime?
  totpSecret                  String?
  totpEnabled                 Boolean                  @default(false)
  tenant                      Tenant                   @relation(fields: [clinicId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([clinicId])
  @@index([deletedAt])
  @@index([deletedAt, createdAt])
}

model Profile {
  id        String    @id @default(cuid())
  tenantId  String    @default("default")
  userId    String    @unique
  firstName String?
  lastName  String?
  phone     String?
  birthDate DateTime?
  timezone  String    @default("America/Chihuahua")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId])
}

model Membership {
  id                   String           @id @default(cuid())
  tenantId             String           @default("default")
  userId               String           @unique
  status               MembershipStatus @default(inactive)
  planId               String?
  stripeSubscriptionId String?          @unique
  stripePriceId        String?
  stripeCustomerId     String?
  planCode             String?
  amount               Float?
  currency             String?
  lastStripeEventId    String?
  lastStripeEventType  String?
  source               String?
  currentPeriodEnd     DateTime?
  gracePeriodEndsAt    DateTime?
  cancelAtPeriodEnd    Boolean          @default(false)
  lastReminderSentAt   DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  payments             Payment[]

  @@index([userId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([stripeCustomerId])
  @@index([tenantId])
}

model Document {
  id           String         @id @default(cuid())
  tenantId     String         @default("default")
  userId       String
  type         String
  status       DocumentStatus @default(pending)
  version      String?
  signedAt     DateTime?
  storageKey   String?        @unique
  signatureKey String?
  contentType  String?
  size         Int?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([tenantId])
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String   @default("default")
  userId       String?
  actorUserId  String?
  targetUserId String?
  action       String
  resourceType String?
  resourceId   String?
  result       String?
  ip           String?
  metadata     Json?
  createdAt    DateTime @default(now())
  user         User?    @relation("AuditLogLegacy", fields: [userId], references: [id], onDelete: SetNull)
  actorUser    User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser   User?    @relation("AuditLogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([resourceType])
  @@index([action])
  @@index([createdAt])
  @@index([resourceType, createdAt])
  @@index([userId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([tenantId])
}

model Lead {
  id              String                @id @default(cuid())
  tenantId        String                @default("default")
  name            String
  email           String
  phone           String
  consent         Boolean
  convertedUserId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  convertedUser   User?                 @relation("LeadConvertedUser", fields: [convertedUserId], references: [id], onDelete: SetNull)
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  attribution     MarketingAttribution?

  @@index([email])
  @@index([phone])
  @@index([createdAt])
  @@index([convertedUserId])
  @@index([tenantId])
}

model MarketingAttribution {
  id              String    @id @default(cuid())
  tenantId        String    @default("default")
  leadId          String?   @unique
  userId          String?
  eventName       String?
  eventId         String?   @unique
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmTerm         String?
  utmContent      String?
  fbp             String?
  fbc             String?
  fbclid          String?
  consent         Boolean?
  metaStatus      String?
  metaError       String?
  requestSummary  Json?
  responseSummary Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sentAt          DateTime?
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  user            User?     @relation("MarketingAttributionUser", fields: [userId], references: [id], onDelete: SetNull)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([eventName])
  @@index([metaStatus])
  @@index([createdAt])
  @@index([tenantId])
}

model MedicalIntake {
  id                 String                   @id @default(cuid())
  tenantId           String                   @default("default")
  userId             String                   @unique
  status             IntakeStatus             @default(draft)
  personalJson       Json?
  historyJson        Json?
  phototype          Int?
  consentAccepted    Boolean                  @default(false)
  signatureKey       String?
  signatureImageData String?                  @db.Text
  submittedAt        DateTime?
  approvedAt         DateTime?
  approvedByUserId   String?
  rejectedAt         DateTime?
  rejectionReason    String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy         User?                    @relation("MedicalIntakeApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  tenant             Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  embeddings         MedicalIntakeEmbedding[]

  @@index([status])
  @@index([approvedByUserId])
  @@index([tenantId])
}

model Appointment {
  id                String             @id @default(cuid())
  clinicId          String             @default("default")
  userId            String
  createdByUserId   String?
  cabinId           String?
  treatmentId       String?
  startAt           DateTime           @db.Timestamptz
  endAt             DateTime           @db.Timestamptz
  status            AppointmentStatus  @default(scheduled)
  reason            String?
  canceledReason    String?
  canceledAt        DateTime?
  confirmedAt       DateTime?
  completedAt       DateTime?
  noShowAt          DateTime?
  autoConfirmedAt   DateTime?
  googleEventId     String?
  googleCalendarId  String?
  syncStatus        String?
  lastSyncedAt      DateTime?
  lastPushedAt      DateTime?
  rescheduledFromId String?
  reminderSentAt    DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation("AppointmentMember", fields: [userId], references: [id], onDelete: Cascade)
  createdBy         User?              @relation("AppointmentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  cabin             AgendaCabin?       @relation(fields: [cabinId], references: [id], onDelete: SetNull)
  treatment         AgendaTreatment?   @relation(fields: [treatmentId], references: [id], onDelete: SetNull)
  rescheduledFrom   Appointment?       @relation("AppointmentReschedule", fields: [rescheduledFromId], references: [id], onDelete: SetNull)
  reschedules       Appointment[]      @relation("AppointmentReschedule")
  sessions          SessionTreatment[]
  tenant            Tenant             @relation(fields: [clinicId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([clinicId])
  @@index([createdByUserId])
  @@index([cabinId])
  @@index([treatmentId])
  @@index([cabinId, startAt, endAt])
  @@index([startAt, endAt])
  @@index([status])
  @@index([status, startAt])
  @@index([userId, startAt])
  @@index([clinicId, userId, startAt, status])
  @@index([googleEventId])
}

model AgendaPolicy {
  id                            String   @id @default(cuid())
  tenantId                      String   @default("default")
  timezone                      String   @default("America/Chihuahua")
  slotMinutes                   Int      @default(30)
  autoConfirmHours              Int      @default(12)
  noShowGraceMinutes            Int      @default(30)
  maxActiveAppointmentsPerWeek  Int      @default(4)
  maxActiveAppointmentsPerMonth Int      @default(12)
  minAdvanceMinutes             Int      @default(120)
  maxAdvanceDays                Int      @default(60)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  tenant                        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId])
}

model AgendaCabin {
  id                  String                     @id @default(cuid())
  tenantId            String                     @default("default")
  name                String
  isActive            Boolean                    @default(true)
  sortOrder           Int                        @default(0)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  appointments        Appointment[]
  blockedSlots        AgendaBlockedSlot[]
  treatments          AgendaTreatment[]
  treatmentCabinRules AgendaTreatmentCabinRule[]
  tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([isActive, sortOrder])
  @@index([tenantId])
}

model AgendaTreatment {
  id                    String                     @id @default(cuid())
  tenantId              String                     @default("default")
  name                  String
  code                  String
  description           String?
  durationMinutes       Int                        @default(45)
  prepBufferMinutes     Int                        @default(0)
  cleanupBufferMinutes  Int                        @default(0)
  cabinId               String?
  requiresSpecificCabin Boolean                    @default(false)
  isActive              Boolean                    @default(true)
  sortOrder             Int                        @default(0)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  cabin                 AgendaCabin?               @relation(fields: [cabinId], references: [id], onDelete: SetNull)
  appointments          Appointment[]
  cabinRules            AgendaTreatmentCabinRule[]
  tenant                Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, code])
  @@index([isActive, sortOrder])
  @@index([cabinId])
  @@index([tenantId])
}

model AgendaTreatmentCabinRule {
  id          String          @id @default(cuid())
  tenantId    String          @default("default")
  treatmentId String
  cabinId     String
  priority    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  treatment   AgendaTreatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  cabin       AgendaCabin     @relation(fields: [cabinId], references: [id], onDelete: Cascade)
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([treatmentId, cabinId])
  @@index([treatmentId, priority])
  @@index([cabinId])
  @@index([tenantId])
}

model AgendaWeeklyRule {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  dayOfWeek Int
  isOpen    Boolean  @default(true)
  startHour Int      @default(9)
  endHour   Int      @default(20)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, dayOfWeek])
  @@index([tenantId])
}

model AgendaSpecialDateRule {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  dateKey   String
  isOpen    Boolean  @default(false)
  startHour Int?
  endHour   Int?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, dateKey])
  @@index([tenantId])
}

model AgendaBlockedSlot {
  id              String       @id @default(cuid())
  tenantId        String       @default("default")
  dateKey         String
  startMinute     Int
  endMinute       Int
  reason          String?
  cabinId         String?
  createdByUserId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  cabin           AgendaCabin? @relation(fields: [cabinId], references: [id], onDelete: SetNull)
  createdBy       User?        @relation("AgendaBlockedSlotCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([dateKey])
  @@index([dateKey, startMinute, endMinute])
  @@index([cabinId])
  @@index([tenantId])
}

model SessionTreatment {
  id                  String       @id @default(cuid())
  tenantId            String       @default("default")
  appointmentId       String?
  userId              String
  staffUserId         String
  laserParametersJson Json?
  notes               String?
  adverseEvents       String?
  memberFeedback      String?
  feedbackAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  appointment         Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  user                User         @relation("SessionMember", fields: [userId], references: [id], onDelete: Cascade)
  staffUser           User         @relation("SessionStaff", fields: [staffUserId], references: [id], onDelete: Restrict)
  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([staffUserId])
  @@index([appointmentId])
  @@index([tenantId])
}

model Payment {
  id                    String        @id @default(cuid())
  tenantId              String        @default("default")
  userId                String
  membershipId          String?
  stripeEventId         String?       @unique
  stripeInvoiceId       String?       @unique
  stripePaymentIntentId String?       @unique
  stripeSubscriptionId  String?
  amount                Int?
  currency              String?
  status                PaymentStatus @default(pending)
  paidAt                DateTime?
  failedAt              DateTime?
  failureCode           String?
  failureMessage        String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership            Membership?   @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([membershipId])
  @@index([status])
  @@index([createdAt])
  @@index([createdAt, status])
  @@index([membershipId, createdAt])
  @@index([userId, status, createdAt])
  @@index([stripeSubscriptionId])
  @@index([tenantId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  userId    String
  token     String   @unique
  expiresAt DateTime @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([tenantId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  userId    String
  token     String   @unique
  expiresAt DateTime @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([tenantId])
}

model ConsentOtpToken {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([tenantId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  userId    String
  tokenHash String   @unique // SHA-256 of raw token — never store plain
  expiresAt DateTime @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([tenantId])
}

model CustomCharge {
  id                    String                @id @default(cuid())
  tenantId              String                @default("default")
  userId                String
  createdByAdminId      String?
  title                 String
  description           String?
  amount                Int // in cents (e.g. 150000 = $1,500 MXN)
  currency              String                @default("mxn")
  type                  CustomChargeType      @default(ONE_TIME)
  interval              CustomChargeInterval? // day | week | month | year | once — only for RECURRING
  otpHash               String?
  otpExpiresAt          DateTime?
  otpAttempts           Int                   @default(0)
  stripeSessionId       String?
  stripeSessionUrl      String?
  stripePaymentIntentId String?
  stripeSubscriptionId  String?
  status                CustomChargeStatus    @default(PENDING_ACCEPTANCE)
  acceptedAt            DateTime?
  paidAt                DateTime?
  nextChargeAt          DateTime? // set on PAID for RECURRING — triggers auto-renewal
  expiresAt             DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant                Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([status, expiresAt])
  @@index([userId, status])
  @@index([nextChargeAt])
  @@index([tenantId])
}

model Notification {
  id        String    @id @default(cuid())
  tenantId  String    @default("default")
  userId    String
  type      String // e.g. "custom_charge_created", "custom_charge_paid", "membership_activated"
  title     String
  body      String?
  data      Json?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([userId, read, createdAt]) // composite for unread badge + pagination
  @@index([tenantId])
}

model WebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
}

model GoogleCalendarIntegration {
  id              String           @id @default(cuid())
  clinicId        String
  email           String
  calendarId      String
  accessTokenEnc  String
  refreshTokenEnc String
  scope           String?
  tokenExpiry     DateTime?
  isActive        Boolean          @default(true)
  watchChannelId  String?
  watchResourceId String?
  watchExpiration DateTime?
  syncToken       String?
  lastSyncAt      DateTime?
  eventFormatMode String           @default("complete")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  jobs            IntegrationJob[]
  tenant          Tenant           @relation(fields: [clinicId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([clinicId])
  @@index([isActive])
  @@index([watchChannelId])
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model DeleteOtp {
  id           String   @id @default(cuid())
  tenantId     String   @default("default")
  actorUserId  String   @unique
  targetUserId String
  otpHash      String
  attempts     Int      @default(0)
  expiresAt    DateTime @db.Timestamptz
  createdAt    DateTime @default(now()) @db.Timestamptz
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([actorUserId])
  @@index([expiresAt])
  @@index([tenantId])
}

model PasswordHistory {
  id           String   @id @default(cuid())
  tenantId     String   @default("default")
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, createdAt])
  @@index([tenantId])
}

model WhatsappOtp {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  userId    String   @unique
  codeHash  String
  phone     String
  attempts  Int      @default(0)
  expiresAt DateTime @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([tenantId])
}

model IntegrationJob {
  id                  String                     @id @default(cuid())
  clinicId            String
  googleIntegrationId String?
  type                String
  payload             Json
  status              IntegrationJobStatus       @default(pending)
  attempts            Int                        @default(0)
  maxAttempts         Int                        @default(8)
  runAt               DateTime                   @default(now())
  lastError           String?
  lockedAt            DateTime?
  finishedAt          DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  googleIntegration   GoogleCalendarIntegration? @relation(fields: [googleIntegrationId], references: [id], onDelete: SetNull)
  tenant              Tenant                     @relation(fields: [clinicId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([status, runAt])
  @@index([clinicId, status, runAt])
  @@index([googleIntegrationId, status, runAt])
}
