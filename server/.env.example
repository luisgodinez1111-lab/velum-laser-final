# ══════════════════════════════════════════════════════════════════════════════
# VELUM LASER — Variables de Entorno del Servidor
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio (está en .gitignore).
# ══════════════════════════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=development            # development | production | test
PORT=4000                       # Puerto en que escucha la API
APP_URL=http://localhost:5173   # URL pública del frontend (para links en emails)
API_URL=http://localhost:4000   # URL pública de la API
CORS_ORIGIN=http://localhost:5173  # Orígenes CORS permitidos (coma-separados en prod)
BASE_URL=http://localhost:4000     # URL base para webhooks y callbacks

# ── Base de Datos ─────────────────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/velum

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# Genera con: node -e "require('crypto').randomBytes(48).toString('hex')"
JWT_SECRET=change-me            # ⚠️  OBLIGATORIO: mínimo 32 caracteres
JWT_EXPIRES_IN=1d               # Duración del token de acceso (en prod: 15m con refresh tokens)
COOKIE_NAME=velum_token         # Nombre de la cookie del token de acceso
COOKIE_DOMAIN=                  # Dominio opcional para cookies cross-subdomain, ej. .velumlaser.com
COOKIE_SAME_SITE=lax            # lax | strict | none. Usar none cuando frontend y API estén en dominios distintos

# ── Refresh Tokens ────────────────────────────────────────────────────────────
REFRESH_TOKEN_EXPIRES_DAYS=30   # Días de validez del refresh token
REFRESH_COOKIE_NAME=velum_refresh
# En producción con seguridad máxima:
# JWT_EXPIRES_IN=15m  ← access token corto, refresh token maneja la sesión

# ── Stripe ────────────────────────────────────────────────────────────────────
# Obtener en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx          # sk_test_... (dev) | sk_live_... (prod)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx     # pk_test_... (dev) | pk_live_... (prod)
STRIPE_WEBHOOK_SECRET=whsec_xxx        # whsec_... — desde dashboard Stripe > Webhooks
STRIPE_PORTAL_RETURN_URL=http://localhost:5173/account
STRIPE_CHECKOUT_BASE_URL=http://localhost:5173

# Depósito de valoración (en centavos MXN — 20000 = $200 MXN)
DEPOSIT_AMOUNT_CENTS=20000

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Obtener en: https://resend.com/api-keys
# Se usan claves separadas por propósito para mejor control y auditoría.
RESEND_FROM_EMAIL=noreply@velumlaser.com
RESEND_KEY_VERIFICATION=re_xxx   # Correos de verificación de email
RESEND_KEY_RESET=re_xxx          # Correos de recuperación de contraseña
RESEND_KEY_REMINDERS=re_xxx      # Recordatorios de citas y pagos
RESEND_KEY_DOCUMENTS=re_xxx      # Notificaciones de documentos firmados
RESEND_KEY_ADMIN_INVITE=re_xxx   # Invitaciones a administradores
RESEND_KEY_NOTIFICATIONS=re_xxx  # Notificaciones generales en-app

# Email del administrador para alertas internas
ADMIN_NOTIFICATION_EMAIL=admin@velumlaser.com

# ── WhatsApp Cloud API (Meta) ──────────────────────────────────────────────────
# Obtener en: https://developers.facebook.com > WhatsApp > API Setup
# Los valores también se pueden sobreescribir desde /admin/whatsapp
META_WA_ACCESS_TOKEN=          # Token de acceso permanente (expira ~60 días — renovar antes)
META_WA_PHONE_NUMBER_ID=       # ID del número de teléfono en Meta Business
META_WA_TEMPLATE_NAME=velum_otp_code
META_WA_REMINDER_TEMPLATE_NAME=velum_appointment_reminder
META_WA_PAYMENT_REMINDER_TEMPLATE_NAME=velum_payment_reminder
META_WA_TEMPLATE_LANG=es_MX
WHATSAPP_OTP_ALLOW_CONSOLE=false  # true: imprime OTP en consola (solo dev sin WhatsApp)

# ── Meta Pixel / Conversions API ──────────────────────────────────────────────
META_ENABLED=false        # true para activar envío de eventos a Meta
META_API_VERSION=v20.0    # Versión de la API de Meta (verificar en docs)
META_PIXEL_ID=            # ID del Pixel de Meta
META_ACCESS_TOKEN=        # Token de la Conversions API (diferente al de WhatsApp)

# ── Google Calendar ────────────────────────────────────────────────────────────
# Obtener en: https://console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/integrations/google-calendar/callback
GOOGLE_SYNC_IGNORE_WINDOW_SECONDS=10  # Ventana para ignorar sincronizaciones duplicadas

# Token secreto para validar notificaciones push de Google Calendar Webhooks
# Genera con: node -e "require('crypto').randomBytes(32).toString('hex')"
GOOGLE_WEBHOOK_TOKEN=

# ── Integrations Encryption ───────────────────────────────────────────────────
# Clave para encriptar credenciales de integraciones en la base de datos
# Genera con: node -e "require('crypto').randomBytes(48).toString('hex')"
INTEGRATIONS_ENC_KEY=change-this-32-byte-secret  # ⚠️  OBLIGATORIO: mínimo 32 caracteres

# ── Configuración de Clínica ──────────────────────────────────────────────────
DEFAULT_CLINIC_ID=default
APPOINTMENT_RESCHEDULE_MIN_HOURS=24  # Horas mínimas para reagendar sin penalización
GRACE_PERIOD_DAYS=5                  # Días de gracia para membresías vencidas

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=/var/velum/uploads        # Directorio para uploads (montar como volumen en Docker)
UPLOAD_MAX_SIZE=10485760             # Tamaño máximo en bytes (10 MB = 10485760)

# ── Error Reporting ───────────────────────────────────────────────────────────
# Webhook para alertas de errores en producción (Slack, Discord, o URL custom)
# Dejar vacío para deshabilitar. Rate-limitado a 10 alertas/minuto.
# Ejemplo Slack: https://hooks.slack.com/services/T.../B.../xxx
ERROR_WEBHOOK_URL=

# ── Health Check ──────────────────────────────────────────────────────────────
# Clave para proteger GET /api/v1/health/detailed (sin clave: endpoint abierto)
# Genera con: node -e "require('crypto').randomBytes(24).toString('hex')"
HEALTH_API_KEY=

# ── Administración inicial (seed) ─────────────────────────────────────────────
ADMIN_EMAIL=admin@velum.mx
ADMIN_PASSWORD=ChangeMe123456!  # ⚠️  Cambiar inmediatamente en producción
RUN_SEED=false                  # true: ejecuta seed al iniciar (solo una vez)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info  # trace | debug | info | warn | error | fatal

# ── Observabilidad: Sentry (Fase 0.5) ─────────────────────────────────────────
# Si SENTRY_DSN está vacío, el SDK NO se inicializa (cero overhead, cero red).
# Crear proyecto en sentry.io → Settings → Client Keys (DSN).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production       # production | staging | development
SENTRY_RELEASE=                     # típicamente el SHA corto del commit deployado
SENTRY_TRACES_SAMPLE_RATE=0.1       # 0.0 a 1.0 — porcentaje de transacciones tracedas
SENTRY_PROFILES_SAMPLE_RATE=0       # 0 = profiling desactivado (costoso)

# ── Observabilidad: OpenTelemetry (Fase 0.6) ──────────────────────────────────
# Si OTEL_EXPORTER_OTLP_ENDPOINT está vacío, el SDK NO se inicializa.
# Para Grafana Cloud free tier:
#   1. Crear stack en grafana.com (free: 50GB logs, 10k metrics series).
#   2. Tomar instance ID y API token desde "OpenTelemetry" en el portal.
#   3. Endpoint: https://otlp-gateway-prod-<region>.grafana.net/otlp
#   4. Headers: Authorization=Basic base64(<instanceId>:<apiToken>)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=velum-api
OTEL_DEPLOYMENT_ENVIRONMENT=production
# Sampler — parentbased mantiene contexto de upstream, traceidratio=0.1 es 10%.
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# ── Multi-tenancy: RLS enforcement (Fase 0.4) ─────────────────────────────────
# false (default): RLS policies existen en BD pero el helper withTenantContext()
#                   no setea app.tenant_id — comportamiento idéntico al actual.
# true:           el helper ejecuta SET LOCAL app.tenant_id por query envuelta.
# IMPORTANTE: postgres (superuser) bypassea RLS. Para que `true` tenga efecto
# real, la app debe conectar como rol no-superuser (Fase 1, próximamente).
RLS_ENFORCE=false

# ── Cifrado de campo PHI (Fase 1.3) ───────────────────────────────────────────
# Master key para cifrar campos médicos sensibles (signatureImageData, etc.).
# DISTINTA de INTEGRATIONS_ENC_KEY: si una se filtra, la otra no expone PHI.
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Mínimo 32 bytes. Una vez en producción, rotación requiere correr el script
# de re-cifrado documentado en docs/runbooks/phi-key-rotation.md.
PHI_MASTER_KEY=
