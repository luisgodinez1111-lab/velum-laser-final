NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/velum
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d
COOKIE_NAME=velum_token
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PORTAL_RETURN_URL=http://localhost:5173/account
STRIPE_CHECKOUT_BASE_URL=http://localhost:5173
UPLOAD_DIR=/var/velum/uploads
UPLOAD_MAX_SIZE=10485760
GRACE_PERIOD_DAYS=5
META_ENABLED=false
META_API_VERSION=v20.0
META_PIXEL_ID=
META_ACCESS_TOKEN=
APPOINTMENT_RESCHEDULE_MIN_HOURS=24
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/integrations/google-calendar/callback
BASE_URL=http://localhost:4000
INTEGRATIONS_ENC_KEY=change-this-32-byte-secret
DEFAULT_CLINIC_ID=default
GOOGLE_SYNC_IGNORE_WINDOW_SECONDS=10
# REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
ADMIN_EMAIL=admin@velum.mx
ADMIN_PASSWORD=ChangeMe123456!
RUN_SEED=false

# Resend — clientes de email por propósito (obtener claves en resend.com)
RESEND_FROM_EMAIL=noreply@velumlaser.com
RESEND_KEY_VERIFICATION=re_xxx
RESEND_KEY_RESET=re_xxx
RESEND_KEY_REMINDERS=re_xxx
RESEND_KEY_DOCUMENTS=re_xxx
RESEND_KEY_ADMIN_INVITE=re_xxx
RESEND_KEY_NOTIFICATIONS=re_xxx

# Notificaciones de administración
ADMIN_NOTIFICATION_EMAIL=admin@velumlaser.com

# WhatsApp Cloud API (Meta) — configuración base via env
# Los valores también se pueden sobreescribir desde el panel admin (/admin/whatsapp)
META_WA_ACCESS_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_TEMPLATE_NAME=velum_otp_code
META_WA_REMINDER_TEMPLATE_NAME=velum_appointment_reminder
META_WA_PAYMENT_REMINDER_TEMPLATE_NAME=velum_payment_reminder
META_WA_TEMPLATE_LANG=es_MX
WHATSAPP_OTP_ALLOW_CONSOLE=false

# Depósito de valoración (en centavos MXN — default 200 MXN = 20000)
DEPOSIT_AMOUNT_CENTS=20000

# Google Calendar Webhooks — token secreto para validar notificaciones push de Google
# Se configura al registrar el canal en la API de Google Calendar
# Genera con: node -e "require('crypto').randomBytes(32).toString('hex')"
GOOGLE_WEBHOOK_TOKEN=

# Stripe — clave pública (pk_test_xxx) — opcional si se configura desde el panel admin
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ── Refresh Tokens ────────────────────────────────────────────────────────────
# Duración del refresh token en días (default: 30)
REFRESH_TOKEN_EXPIRES_DAYS=30
# Nombre de la cookie del refresh token (default: velum_refresh)
REFRESH_COOKIE_NAME=velum_refresh
# En producción, acortar JWT de acceso para mayor seguridad:
# JWT_EXPIRES_IN=15m   ← descomentar en producción (requiere refresh tokens activos)

# ── Error Reporting ───────────────────────────────────────────────────────────
# URL de webhook para alertas de errores (Slack, Discord, o custom)
# Dejar vacío para deshabilitar. Rate-limitado a 10 alertas/minuto.
# Ejemplo Slack: https://hooks.slack.com/services/xxx/yyy/zzz
ERROR_WEBHOOK_URL=

# ── Health Check ─────────────────────────────────────────────────────────────
# Clave para proteger GET /api/v1/health/detailed (opcional)
# Si se configura, enviar como header: X-Health-Key: <valor>
# Genera con: node -e "require('crypto').randomBytes(24).toString('hex')"
HEALTH_API_KEY=
