NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/velum
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d
COOKIE_NAME=velum_token
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PORTAL_RETURN_URL=http://localhost:5173/account
STRIPE_CHECKOUT_BASE_URL=http://localhost:5173
UPLOAD_DIR=/var/velum/uploads
UPLOAD_MAX_SIZE=10485760
GRACE_PERIOD_DAYS=5
META_ENABLED=false
META_API_VERSION=v20.0
META_PIXEL_ID=
META_ACCESS_TOKEN=
APPOINTMENT_RESCHEDULE_MIN_HOURS=24
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/integrations/google-calendar/callback
BASE_URL=http://localhost:4000
INTEGRATIONS_ENC_KEY=change-this-32-byte-secret
DEFAULT_CLINIC_ID=default
GOOGLE_SYNC_IGNORE_WINDOW_SECONDS=10
# REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
ADMIN_EMAIL=admin@velum.mx
ADMIN_PASSWORD=ChangeMe123456!
RUN_SEED=false

# Resend — clientes de email por propósito (obtener claves en resend.com)
RESEND_FROM_EMAIL=noreply@velumlaser.com
RESEND_KEY_VERIFICATION=re_xxx
RESEND_KEY_RESET=re_xxx
RESEND_KEY_REMINDERS=re_xxx
RESEND_KEY_DOCUMENTS=re_xxx
RESEND_KEY_ADMIN_INVITE=re_xxx
RESEND_KEY_NOTIFICATIONS=re_xxx

# Notificaciones de administración
ADMIN_NOTIFICATION_EMAIL=admin@velumlaser.com

# WhatsApp Cloud API (Meta) — configuración base via env
# Los valores también se pueden sobreescribir desde el panel admin (/admin/whatsapp)
META_WA_ACCESS_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_TEMPLATE_NAME=velum_otp_code
META_WA_REMINDER_TEMPLATE_NAME=velum_appointment_reminder
META_WA_PAYMENT_REMINDER_TEMPLATE_NAME=velum_payment_reminder
META_WA_TEMPLATE_LANG=es_MX
WHATSAPP_OTP_ALLOW_CONSOLE=false

# Depósito de valoración (en centavos MXN — default 200 MXN = 20000)
DEPOSIT_AMOUNT_CENTS=20000
